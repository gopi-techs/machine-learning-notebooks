    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(\"cpi_data.csv\")\n",
    "\n",
    "print(df.head())\n",
    "print(df.info())\n",
    "\n",
    "df.plot()\n",
    "plt.show()\n"
   ]
