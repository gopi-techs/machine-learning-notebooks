   "source": [
    "# 1. Clean the Month column (removes hidden spaces like \" January \")\n",
    "df['Month'] = df['Month'].astype(str).str.strip()\n",
    "\n",
    "# 2. Combine and convert using 'coerce' to identify problematic rows\n",
    "df['date'] = pd.to_datetime(\n",
    "    df['Year'].astype(str) + '-' + df['Month'], \n",
    "    format='%Y-%B', \n",
    "    errors='coerce'\n",
    ")\n",
    "\n",
    "# 3. Check if any rows failed (they will be NaT - Not a Time)\n",
    "if df['date'].isnull().any():\n",
    "    print(\"Warning: Some dates could not be parsed:\")\n",
    "    print(df[df['date'].isnull()][['Year', 'Month']])\n",
    "df.sort_values('date', inplace=True)\n",
    "\n",
    "plt.figure(figsize=(10,5))\n",
    "plt.plot(df['date'],df['Cereals and products'])\n",
    "plt.title('Cereal Price Index Over Time')\n",
    "plt.xlabel(\"Year\")\n",
    "plt.ylabel(\"Index Value\")\n",
    "plt.show()\n",
    "\n",
    "\n"
   ]
